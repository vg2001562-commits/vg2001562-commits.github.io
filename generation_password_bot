async def settings(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Обработчик команды /settings
    """
    # Получаем текущие настройки или устанавливаем значения по умолчанию
    user_data = context.user_data
    
    if 'length' not in user_data:
        user_data['length'] = 12
    if 'use_digits' not in user_data:
        user_data['use_digits'] = True
    if 'use_special' not in user_data:
        user_data['use_special'] = True
    
    settings_text = (
        f"⚙️ Текущие настройки генерации:\n\n"
        f"📏 Длина пароля: {user_data['length']}\n"
        f"🔢 Использовать цифры: {'✅' if user_data['use_digits'] else '❌'}\n"
        f"🔣 Использовать спецсимволы: {'✅' if user_data['use_special'] else '❌'}\n\n"
        f"Выберите параметр для изменения:"
    )
    
    # Создаем инлайн-клавиатуру для настроек
    keyboard = [
        [InlineKeyboardButton(f"📏 Длина: {user_data['length']}", callback_data='change_length')],
        [InlineKeyboardButton(f"🔢 Цифры: {'✅' if user_data['use_digits'] else '❌'}", callback_data='toggle_digits')],
        [InlineKeyboardButton(f"🔣 Спецсимволы: {'✅' if user_data['use_special'] else '❌'}", callback_data='toggle_special')],
        [InlineKeyboardButton("🔙 Назад", callback_data='back_to_main')]
    ]
    reply_markup = InlineKeyboardMarkup(keyboard)
    
    if update.message:
        await update.message.reply_text(settings_text, reply_markup=reply_markup)
    else:
        await update.callback_query.edit_message_text(settings_text, reply_markup=reply_markup)

async def generate(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Обработчик команды /generate
    """
    user_data = context.user_data
    
    # Получаем настройки пользователя или используем значения по умолчанию
    length = user_data.get('length', 12)
    use_digits = user_data.get('use_digits', True)
    use_special = user_data.get('use_special', True)
    
    # Проверяем, не передана ли длина в аргументе команды
    if context.args and context.args[0].isdigit():
        length = int(context.args[0])
        # Ограничиваем длину
        if length < 6:
            length = 6
        elif length > 32:
            length = 32
    
    # Генерируем пароль
    password = generate_password(length, use_digits, use_special)
    
    # Создаем клавиатуру с действиями
    keyboard = [
        [InlineKeyboardButton("🔄 Сгенерировать снова", callback_data='generate')],
        [InlineKeyboardButton("⚙️ Настройки", callback_data='settings')]
    ]
    reply_markup = InlineKeyboardMarkup(keyboard)
    
    message = f"🔐 Ваш пароль (длина: {len(password)}):\n\n`{password}`\n\n<i>Пароль скопирован в буфер обмена? Нажмите на сообщение, чтобы скопировать</i>"
    
    if update.message:
        await update.message.reply_text(message, parse_mode='HTML', reply_markup=reply_markup)
    else:
        await update.callback_query.edit_message_text(message, parse_mode='HTML', reply_markup=reply_markup)

async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Обработчик нажатий на инлайн-кнопки
    """
    query = update.callback_query
    await query.answer()
    
    if query.data == 'generate':
        await generate(update, context)
    
    elif query.data == 'settings':
        await settings(update, context)
    
    elif query.data == 'help':
        help_text = (
            "📚 Как пользоваться ботом:\n\n"
            "/start - начать работу с ботом\n"
            "/generate - сгенерировать пароль (текущие настройки)\n"
            "/generate 16 - сгенерировать пароль длиной 16 символов\n"
            "/settings - настроить параметры генерации\n\n"
            "В настройках можно выбрать:\n"
            "• Длину пароля (от 6 до 32 символов)\n"
            "• Использование цифр\n"
            "• Использование специальных символов"
        )
        await query.edit_message_text(help_text)
    
    elif query.data == 'change_length':
        keyboard = []
        # Создаем кнопки для выбора длины
        row = []
        for i in range(6, 33, 2):
            row.append(InlineKeyboardButton(str(i), callback_data=f'set_length_{i}'))
            if len(row) == 4:
                keyboard.append(row)
                row = []
        if row:
            keyboard.append(row)
        
        keyboard.append([InlineKeyboardButton("🔙 Назад к настройкам", callback_data='settings')])
        reply_markup = InlineKeyboardMarkup(keyboard)
        await query.edit_message_text("📏 Выберите длину пароля (от 6 до 32):", reply_markup=reply_markup)
    
    elif query.data.startswith('set_length_'):
        length = int(query.data.replace('set_length_', ''))
        context.user_data['length'] = length
        await query.edit_message_text(f"✅ Длина пароля установлена: {length}")
        # Возвращаемся к настройкам
        await settings(update, context)
    
    elif query.data == 'toggle_digits':
        context.user_data['use_digits'] = not context.user_data.get('use_digits', True)
        await settings(update, context)
    
    elif query.data == 'toggle_special':
        context.user_data['use_special'] = not context.user_data.get('use_special', True)
        await settings(update, context)
    
    elif query.data == 'back_to_main':
        keyboard = [
            [InlineKeyboardButton("🔑 Сгенерировать пароль", callback_data='generate')],
            [InlineKeyboardButton("⚙️ Настройки", callback_data='settings')],
            [InlineKeyboardButton("❓ Помощь", callback_data='help')]
        ]
        reply_markup = InlineKeyboardMarkup(keyboard)
        await query.edit_message_text("🔐 Главное меню", reply_markup=reply_markup)

def main():
    """
    Основная функция запуска бота
    """
    # Создаем приложение
    application = Application.builder().token(BOT_TOKEN).build()
    
    # Регистрируем обработчики команд
    application.add_handler(CommandHandler("start", start))
    application.add_handler(CommandHandler("help", help_command))
    application.add_handler(CommandHandler("settings", settings))
    application.add_handler(CommandHandler("generate", generate))
    
    # Регистрируем обработчик инлайн-кнопок
    application.add_handler(CallbackQueryHandler(button_handler))
    
    # Запускаем бота
    print("Бот запущен...")
    application.run_polling(allowed_updates=Update.ALL_TYPES)

if __name__ == '__main__':
    main()
